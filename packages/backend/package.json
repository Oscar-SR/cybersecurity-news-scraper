{
  "name": "cybersecurity-news-scraper-backend",
  "private": true,
  "type": "commonjs",
  "main": "scr/index.ts",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc --pretty",
    "start": "node dist/index.js",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prettier": "prettier . --write --ignore-path ../../.prettierignore",
    "prettier:check": "prettier . --check --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "cors": "2.8.5",
    "date-fns": "4.1.0",
    "dotenv": "16.4.7",
    "express": "5.1.0",
    "playwright": "1.56.1",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.0.3",
    "@types/supertest": "6.0.3",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.5.0",
    "nodemon": "3.1.11",
    "prettier": "3.7.4",
    "supertest": "7.1.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.1",
    "vitest": "4.0.14"
  }
}
