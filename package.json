{
  "name": "cybersecurity-news-scraper",
  "version": "1.0.0",
  "description": "A full-stack application that scrapes the latest cybersecurity news from multiple open sources and presents it in a user-friendly interface",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "dev": "concurrently npm:dev:backend npm:dev:frontend",
    "build:backend": "npm run build -w packages/backend",
    "build:frontend": "npm run build -w packages/frontend",
    "build": "concurrently npm:build:backend npm:build:frontend",
    "test:backend": "npm test -w packages/backend",
    "test:frontend": "npm test -w packages/frontend",
    "test": "concurrently npm:test:backend npm:test:frontend",
    "lint": "npm run lint -w packages/backend && npm run lint -w packages/frontend",
    "start:backend": "npm run start -w packages/backend",
    "start:frontend": "npm run start -w packages/frontend",
    "start": "concurrently npm:start:backend npm:start:frontend",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "i18n:extract": "npm run i18n:extract -w packages/frontend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oscar-SR/cybersecurity-news-scraper.git",
    "directory": "backend"
  },
  "keywords": [
    "scraping",
    "osint",
    "playwright",
    "node.js"
  ],
  "author": "Óscar Sánchez Rubio",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Oscar-SR/cybersecurity-news-scraper/issues"
  },
  "homepage": "https://github.com/Oscar-SR/cybersecurity-news-scraper#readme",
  "devDependencies": {
    "concurrently": "10.0.3",
    "prettier": "3.7.4"
  }
}
